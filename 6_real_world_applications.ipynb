   "source": [
    "# Test the conversational AI assistant\n",
    "convo_graph = create_conversational_ai_graph()\n",
    "\n",
    "# Example: User greeting and asking for help with order\n",
    "initial_state_convo = {\n",
    "    'user_input': 'Hi, I need help with my recent order',\n",
    "    'chat_history': [],\n",
    "    'context': {'user_id': 'user123'},\n",
    "    'current_intent': '',\n",
    "    'response': '',\n",
    "    'needs_followup': False,\n",
