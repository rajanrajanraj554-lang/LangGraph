   "source": [
    "# Tutorial 2: Research Assistants\n",
    "\n",
    "# For this example, we'll simulate a research assistant\n",
    "# In a real implementation, you would integrate with search APIs\n",
    "\n",
    "# Define state for research assistant\n",
    "class ResearchState(TypedDict):\n",
    "    research_topic: str\n",
    "    search_queries: List[str]\n",
    "    search_results: List[Dict[str, Any]]\n",
    "    synthesized_knowledge: str\n",
    "    sources: List[str]\n",
    "    research_steps: List[str]\n",
    "    final_report: str\n",
    "\n",
    "# Function to simulate web search\n",
    "def simulate_web_search(query: str) -> List[Dict[str, str]]:\n",
    "    # In a real implementation, this would call a search API\n",
    "    # For simulation, we'll return mock results\n",
    "    mock_results = [\n",
    "        {\"title\": f\"Result 1 for {query}\", \"url\": f\"https://example.com/{query}/1\", \"snippet\": f\"This is a snippet for the first result about {query}\"},\n",
    "        {\"title\": f\"Result 2 for {query}\", \"url\": f\"https://example.com/{query}/2\", \"snippet\": f\"This is another result related to {query} showing important information\"},\n",
    "        {\"title\": f\"Result 3 for {query}\", \"url\": f\"https://example.com/{query}/3\", \"snippet\": f\"Third result providing additional context about {query}\"}\n",
    "    ]\n",
    "    return mock_results\n",
    "\n",
    "# Plan the research approach\n",
    "def plan_research(state: ResearchState):\n",
    "    topic = state['research_topic']\n",
    "    \n",
    "    # Generate search queries based on the topic\n",
    "    queries = [\n",
    "        f\"overview of {topic}\",\n",
    "        f\"recent developments in {topic}\",\n",
    "        f\"challenges and opportunities in {topic}\"\n",
    "    ]\n",
    "    \n",
    "    research_plan = f\"Research plan for '{topic}':\\n1. Search for overview\\n2. Find recent developments\\n3. Identify challenges and opportunities\"\n",
    "    \n",
    "    return {\n",
    "        'search_queries': queries,\n",
    "        'research_steps': [research_plan]\n",
    "    }\n",
    "\n",
    "# Execute search queries\n",
    "def execute_searches(state: ResearchState):\n",
    "    queries = state['search_queries']\n",
    "    all_results = []\n",
    "    all_sources = []\n",
    "    \n",
    "    for query in queries:\n",
    "        # Simulate web search\n",
    "        results = simulate_web_search(query)\n",
    "        all_results.extend(results)\n",
    "        \n",
    "        # Collect sources\n",
    "        sources = [r['url'] for r in results]\n",
    "        all_sources.extend(sources)\n",
    "    \n",
    "    search_step = f\"Executed {len(queries)} searches and collected {len(all_results)} results\"\n",
    "    \n",
    "    return {\n",
    "        'search_results': all_results,\n",
    "        'sources': all_sources,\n",
    "        'research_steps': state.get('research_steps', []) + [search_step]\n",
    "    }\n",
    "\n",
    "# Synthesize the gathered information\n",
    "def synthesize_information(state: ResearchState):\n",
    "    results = state['search_results']\n",
    "    topic = state['research_topic']\n",
    "    \n",
    "    # Extract key points from results\n",
    "    key_points = []\n",
    "    for result in results[:5]:  # Take first 5 results\n",
    "        key_points.append(result['snippet'])\n",
    "    \n",
    "    synthesized_content = f\"Based on research about '{topic}', key findings include: {'; '.join(key_points[:3])}\"\n",
    "    \n",
    "    synthesis_step = f\"Synthesized information from {len(results)} sources\"\n",
    "    \n",
    "    return {\n",
    "        'synthesized_knowledge': synthesized_content,\n",
    "        'research_steps': state.get('research_steps', []) + [synthesis_step]\n",
    "    }\n",
    "\n",
    "# Generate final research report\n",
    "def generate_report(state: ResearchState):\n",
    "    topic = state['research_topic']\n",
    "    synthesized = state['synthesized_knowledge']\n",
    "    sources = state['sources'][:5]  # Limit to first 5 sources\n",
    "    \n",
    "    report = f\"Research Report on '{topic}':\\n{synthesized}\\n\\nSources consulted: {sources}\"\n",
    "    \n",
    "    report_step = f\"Generated final report on {topic}\"\n",
    "    \n",
    "    return {\n",
    "        'final_report': report,\n",
    "        'research_steps': state.get('research_steps', []) + [report_step]\n",
    "    }\n",
    "\n",
    "# Build the research assistant graph\n",
    "def create_research_assistant_graph():\n",
    "    workflow = StateGraph(ResearchState)\n",
    "    \n",
    "    # Add nodes\n",
    "    workflow.add_node('plan_research', plan_research)\n",
    "    workflow.add_node('execute_searches', execute_searches)\n",
    "    workflow.add_node('synthesize_information', synthesize_information)\n",
    "    workflow.add_node('generate_report', generate_report)\n",
    "    \n",
    "    # Set entry point\n",
    "    workflow.set_entry_point('plan_research')\n",
    "    \n",
    "    # Add edges\n",
    "    workflow.add_edge('plan_research', 'execute_searches')\n",
    "    workflow.add_edge('execute_searches', 'synthesize_information')\n",
    "    workflow.add_edge('synthesize_information', 'generate_report')\n",
    "    workflow.add_edge('generate_report', END)\n",
    "    \n",
    "    return workflow.compile()"
   ]
  },
