   "source": [
    "# Tutorial 3: Data Analysis Workflows\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from datetime import datetime, timedelta\n",
    "\n",
    "# Define state for data analysis workflow\n",
    "class DataAnalysisState(TypedDict):\n",
    "    raw_data: List[Dict[str, Any]]\n",
    "    processed_data: pd.DataFrame\n",
    "    analysis_results: Dict[str, Any]\n",
    "    visualizations: List[str]\n",
    "    insights: List[str]\n",
    "    data_quality_report: str\n",
    "    transformations_applied: List[str]\n",
    "\n",
    "# Generate sample data for demonstration\n",
    "def generate_sample_data() -> List[Dict[str, Any]]:\n",
    "    np.random.seed(42)\n",
    "    dates = [datetime.now() - timedelta(days=x) for x in range(30, 0, -1)]\n",
    "    \n",
    "    data = []\n",
    "    for i, date in enumerate(dates):\n",
    "        data.append({\n",
    "            'date': date.strftime('%Y-%m-%d'),\n",
    "            'sales': round(np.random.normal(1000, 200) + i * 5, 2),  # Slight upward trend\n",
    "            'customers': np.random.poisson(50) + i % 7,  # Some weekly pattern\n",
    "            'region': np.random.choice(['North', 'South', 'East', 'West']),\n",
    "            'product_category': np.random.choice(['Electronics', 'Clothing', 'Books', 'Home'])\n",
    "        })\n",
    "    \n",
    "    return data\n",
    "\n",
    "# Load and validate data\n",
    "def load_data(state: DataAnalysisState):\n",
    "    # In a real implementation, this would load from a file or database\n",
    "    raw_data = state.get('raw_data') or generate_sample_data()\n",
    "    df = pd.DataFrame(raw_data)\n",
    "    \n",
    "    # Convert date column to datetime\n",
    "    df['date'] = pd.to_datetime(df['date'])\n",
    "    \n",
    "    # Basic data quality checks\n",
    "    missing_values = df.isnull().sum().to_dict()\n",
    "    data_types = df.dtypes.to_dict()\n",
    "    \n",
    "    quality_report = f\"Data loaded with {len(df)} rows. Missing values: {missing_values}. Data types: {data_types}\"\n",
    "    \n",
    "    return {\n",
    "        'raw_data': raw_data,\n",
    "        'processed_data': df,\n",
    "        'data_quality_report': quality_report,\n",
    "        'transformations_applied': ['data_loading']\n",
    "    }\n",
    "\n",
    "# Clean and transform data\n",
    "def clean_data(state: DataAnalysisState):\n",
    "    df = state['processed_data'].copy()\n",
    "    original_shape = df.shape\n",
    "    \n",
    "    # Remove duplicates\n",
    "    df = df.drop_duplicates()\n",
    "    \n",
    "    # Handle missing values (fill with mean for numeric, mode for categorical)\n",
    "    for col in df.columns:\n",
    "        if df[col].dtype in ['int64', 'float64']:\n",
    "            df[col] = df[col].fillna(df[col].mean())\n",
    "        else:\n",
    "            df[col] = df[col].fillna(df[col].mode()[0] if not df[col].mode().empty else 'Unknown')\n",
    "    \n",
    "    # Add derived features\n",
    "    df['day_of_week'] = df['date'].dt.dayofweek\n",
    "    df['month'] = df['date'].dt.month\n",
    "    df['sales_per_customer'] = df['sales'] / (df['customers'] + 1)  # Adding 1 to avoid division by zero\n",
    "    \n",
    "    cleaning_report = f\"Data cleaned: {original_shape[0] - len(df)} duplicates removed, missing values handled, new features added.\"\n",
    "    \n",
    "    transformations = state.get('transformations_applied', []) + ['duplicate_removal', 'missing_value_handling', 'feature_engineering']\n",
    "    \n",
    "    return {\n",
    "        'processed_data': df,\n",
    "        'data_quality_report': state.get('data_quality_report', '') + f\" {cleaning_report}\",\n",
    "        'transformations_applied': transformations\n",
    "    }\n",
    "\n",
    "# Perform statistical analysis\n",
    "def analyze_data(state: DataAnalysisState):\n",
    "    df = state['processed_data']\n",
    "    \n",
    "    # Calculate basic statistics\n",
    "    stats = {\n",
    "        'mean_sales': df['sales'].mean(),\n",
    "        'median_sales': df['sales'].median(),\n",
    "        'std_sales': df['sales'].std(),\n",
    "        'total_sales': df['sales'].sum(),\n",
    "        'correlation_sales_customers': df['sales'].corr(df['customers']) if len(df) > 1 else 0\n",
    "    }\n",
    "    \n",
    "    # Group analysis\n",
    "    region_sales = df.groupby('region')['sales'].agg(['mean', 'sum']).round(2).to_dict()\n",
    "    category_sales = df.groupby('product_category')['sales'].agg(['mean', 'sum']).round(2).to_dict()\n",
    "    \n",
    "    analysis_report = {\n",
    "        'basic_stats': stats,\n",
    "        'regional_performance': region_sales,\n",
    "        'category_performance': category_sales\n",
    "    }\n",
    "    \n",
    "    analysis_step = f\"Statistical analysis completed. Mean sales: ${stats['mean_sales']:.2f}\"\n",
    "    \n",
    "    return {\n",
    "        'analysis_results': analysis_report,\n",
    "        'transformations_applied': state.get('transformations_applied', []) + ['statistical_analysis'],\n",
    "        'insights': [f\"Average daily sales: ${stats['mean_sales']:.2f}\", f\"Sales-customer correlation: {stats['correlation_sales_customers']:.2f}\"]\n",
    "    }\n",
    "\n",
    "# Generate insights from the analysis\n",
    "def generate_insights(state: DataAnalysisState):\n",
    "    df = state['processed_data']\n",
    "    analysis = state['analysis_results']\n",
    "    \n",
    "    insights = []\n",
    "    \n",
    "    # Trend analysis\n",
    "    recent_trend = df.tail(10)['sales'].mean() - df.head(10)['sales'].mean()\n",
    "    if recent_trend > 50:\n",
    "        insights.append(f\"Strong positive trend detected: sales increased by ${recent_trend:.2f} over the period\")\n",
    "    elif recent_trend < -50:\n",
    "        insights.append(f\"Declining trend detected: sales decreased by ${abs(recent_trend):.2f} over the period\")\n",
    "    else:\n",
    "        insights.append(f\"Stable sales pattern: minor changes of ${recent_trend:.2f} over the period\")\n",
    "    \n",
    "    # Top performing segments\n",
    "    top_region = df.groupby('region')['sales'].sum().idxmax()\n",
    "    top_category = df.groupby('product_category')['sales'].sum().idxmax()\n",
    "    \n",
    "    insights.append(f\"Top performing region: {top_region}\")\n",
    "    insights.append(f\"Top performing category: {top_category}\")\n",
    "    \n",
    "    # Day of week analysis\n",
    "    best_day = df.groupby('day_of_week')['sales'].mean().idxmax()\n",
    "    day_map = {0: 'Monday', 1: 'Tuesday', 2: 'Wednesday', 3: 'Thursday', 4: 'Friday', 5: 'Saturday', 6: 'Sunday'}\n",
    "    insights.append(f\"Best sales day: {day_map[best_day]}\")\n",
    "    \n",
    "    insight_generation = f\"Generated {len(insights)} business insights from the data\"\n",
    "    \n",
    "    return {\n",
    "        'insights': state.get('insights', []) + insights,\n",
    "        'transformations_applied': state.get('transformations_applied', []) + ['insight_generation'],\n",
    "        'analysis_results': {**state.get('analysis_results', {}), 'insights': insights}\n",
    "    }\n",
    "\n",
    "# Create visualization descriptions (in a real app, this would generate actual plots)\n",
    "def create_visualizations(state: DataAnalysisState):\n",
    "    df = state['processed_data']\n",
    "    \n",
    "    visualizations = [\n",
    "        f\"Line chart of sales over time ({len(df)} days)\",\n",
    "        f\"Bar chart of sales by region ({df['region'].nunique()} regions)\",\n",
    "        f\"Pie chart of sales by product category ({df['product_category'].nunique()} categories)\",\n",
    "        \"Heatmap of sales by day of week and time period\"\n",
    "    ]\n",
    "    \n",
    "    viz_creation = f\"Created {len(visualizations)} visualization recommendations\"\n",
    "    \n",
    "    return {\n",
    "        'visualizations': visualizations,\n",
    "        'transformations_applied': state.get('transformations_applied', []) + ['visualization_planning']\n",
    "    }\n",
    "\n",
    "# Build the data analysis workflow graph\n",
    "def create_data_analysis_graph():\n",
    "    workflow = StateGraph(DataAnalysisState)\n",
    "    \n",
    "    # Add nodes\n",
    "    workflow.add_node('load_data', load_data)\n",
    "    workflow.add_node('clean_data', clean_data)\n",
    "    workflow.add_node('analyze_data', analyze_data)\n",
    "    workflow.add_node('generate_insights', generate_insights)\n",
    "    workflow.add_node('create_visualizations', create_visualizations)\n",
    "    \n",
    "    # Set entry point\n",
    "    workflow.set_entry_point('load_data')\n",
    "    \n",
    "    # Add edges\n",
    "    workflow.add_edge('load_data', 'clean_data')\n",
    "    workflow.add_edge('clean_data', 'analyze_data')\n",
    "    workflow.add_edge('analyze_data', 'generate_insights')\n",
    "    workflow.add_edge('generate_insights', 'create_visualizations')\n",
    "    workflow.add_edge('create_visualizations', END)\n",
    "    \n",
    "    return workflow.compile()"
   ]
  },
