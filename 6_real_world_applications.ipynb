    "## 5. Planning and Execution Systems\\n\\nLearning objectives:\\n- Create agents that can plan and execute complex tasks\\n- Implement task decomposition and scheduling\\n- Design action execution and monitoring"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tutorial 5: Planning and Execution Systems\n",
    "\n",
    "# Define state for planning and execution\n",
    "class PlanningExecutionState(TypedDict):\n",
    "    goal: str\n",
    "    plan: List[Dict[str, Any]]\n",
    "    executed_tasks: List[Dict[str, Any]]\n",
    "    current_task: str\n",
    "    task_status: Dict[str, str]\n",
    "    resources_needed: List[str]\n",
    "    dependencies: Dict[str, List[str]]\n",
    "    execution_log: List[str]\n",
    "\n",
    "# Function to generate a plan based on a goal\n",
    "def generate_plan(state: PlanningExecutionState):\n",
    "    goal = state['goal']\n",
    "    \n",
    "    # For demonstration, we'll create a simple plan based on keywords in the goal\n",
    "    if 'website' in goal.lower():\n",
    "        plan = [\n",
    "            {'id': 'task_1', 'description': 'Research requirements', 'duration': 2, 'dependencies': []},\n",
    "            {'id': 'task_2', 'description': 'Design wireframes', 'duration': 3, 'dependencies': ['task_1']},\n",
    "            {'id': 'task_3', 'description': 'Develop frontend', 'duration': 5, 'dependencies': ['task_2']},\n",
    "            {'id': 'task_4', 'description': 'Develop backend', 'duration': 4, 'dependencies': ['task_1']},\n",
    "            {'id': 'task_5', 'description': 'Integrate frontend and backend', 'duration': 2, 'dependencies': ['task_3', 'task_4']},\n",
    "            {'id': 'task_6', 'description': 'Test functionality', 'duration': 3, 'dependencies': ['task_5']},\n",
    "            {'id': 'task_7', 'description': 'Deploy website', 'duration': 1, 'dependencies': ['task_6']}\n",
    "        ]\n",
    "        resources = ['designer', 'frontend_dev', 'backend_dev', 'tester', 'devops']\n",
    "    elif 'marketing' in goal.lower():\n",
    "        plan = [\n",
    "            {'id': 'task_1', 'description': 'Market research', 'duration': 4, 'dependencies': []},\n",
    "            {'id': 'task_2', 'description': 'Define target audience', 'duration': 2, 'dependencies': ['task_1']},\n",
    "            {'id': 'task_3', 'description': 'Create marketing materials', 'duration': 5, 'dependencies': ['task_2']},\n",
    "            {'id': 'task_4', 'description': 'Set up campaigns', 'duration': 3, 'dependencies': ['task_3']},\n",
    "            {'id': 'task_5', 'description': 'Launch campaigns', 'duration': 1, 'dependencies': ['task_4']},\n",
    "            {'id': 'task_6', 'description': 'Monitor performance', 'duration': 7, 'dependencies': ['task_5']}\n",
    "        ]\n",
    "        resources = ['marketing_specialist', 'content_creator', 'analyst']\n",
    "    else:\n",
    "        # Default plan\n",
    "        plan = [\n",
    "            {'id': 'task_1', 'description': 'Define requirements', 'duration': 2, 'dependencies': []},\n",
    "            {'id': 'task_2', 'description': 'Create initial draft', 'duration': 3, 'dependencies': ['task_1']},\n",
    "            {'id': 'task_3', 'description': 'Review and revise', 'duration': 2, 'dependencies': ['task_2']},\n",
    "            {'id': 'task_4', 'description': 'Finalize deliverable', 'duration': 1, 'dependencies': ['task_3']}\n",
    "        ]\n",
    "        resources = ['project_manager', 'specialist']\n",
    "    \n",
    "    # Extract dependencies\n",
    "    dependencies = {}\n",
    "    for task in plan:\n",
    "        dependencies[task['id']] = task['dependencies']\n",
    "    \n",
    "    plan_generation_log = f\"Generated plan with {len(plan)} tasks for goal: {goal}\"\n",
    "    \n",
    "    return {\n",
    "        'plan': plan,\n",
    "        'dependencies': dependencies,\n",
    "        'resources_needed': resources,\n",
    "        'task_status': {task['id']: 'pending' for task in plan},\n",
    "        'execution_log': [plan_generation_log]\n",
    "    }\n",
    "\n",
    "# Execute tasks in the plan\n",
    "def execute_tasks(state: PlanningExecutionState):\n",
    "    plan = state['plan']\n",
    "    task_status = state['task_status'].copy()\n",
    "    executed_tasks = []\n",
    "    execution_log = state.get('execution_log', [])\n",
    "    \n",
    "    # Simple execution logic - in reality, this would check dependencies\n",
    "    for task in plan:\n",
    "        task_id = task['id']\n",
    "        \n",
    "        # Check if all dependencies are completed\n",
    "        deps_satisfied = all(task_status.get(dep, 'not_started') == 'completed' for dep in task['dependencies'])\n",
    "        \n",
    "        if deps_satisfied or task_status.get(task_id) != 'completed':\n",
    "            # Simulate task execution\n",
    "            import time\n",
    "            time.sleep(0.1)  # Simulate work\n",
    "            \n",
    "            # Mark task as completed\n",
    "            task_status[task_id] = 'completed'\n",
    "            \n",
    "            executed_task = {\n",
    "                'id': task_id,\n",
    "                'description': task['description'],\n",
    "                'status': 'completed',\n",
    "                'executed_at': 'now',\n",
    "                'duration': task['duration']\n",
    "            }\n",
    "            \n",
    "            executed_tasks.append(executed_task)\n",
    "            execution_log.append(f\"Completed task '{task['description']}' (ID: {task_id})\")\n",
    "        else:\n",
    "            execution_log.append(f\"Skipped task '{task['description']}' due to unmet dependencies\")\n",
    "    \n",
    "    return {\n",
    "        'executed_tasks': executed_tasks,\n",
    "        'task_status': task_status,\n",
    "        'execution_log': execution_log\n",
    "    }\n",
    "\n",
    "# Monitor and adjust the plan as needed\n",
    "def monitor_execution(state: PlanningExecutionState):\n",
    "    executed_tasks = state['executed_tasks']\n",
    "    plan = state['plan']\n",
    "    \n",
    "    # Calculate completion percentage\n",
    "    total_tasks = len(plan)\",
    "    completed_tasks = len(executed_tasks)\n",
    "    completion_percentage = (completed_tasks / total_tasks) * 100 if total_tasks > 0 else 0\n",
    "    \n",
    "    # Check for potential issues\n",
    "    issues = []\n",
    "    if completion_percentage < 50 and len(executed_tasks) > total_tasks * 0.7:\n",
    "        issues.append(\"Unexpected execution pattern detected\")\n",
    "    \n",
    "    # Generate summary\n",
    "    summary = f\"Execution monitoring: {completed_tasks}/{total_tasks} tasks completed ({completion_percentage:.1f}%). Issues detected: {len(issues)}\"\n",
    "    \n",
    "    execution_log = state.get('execution_log', []) + [f\"Monitoring report: {summary}\"]\n",
    "    \n",
    "    return {\n",
    "        'execution_log': execution_log\n",
    "    }\n",
    "\n",
    "# Generate final report\n",
    "def generate_report(state: PlanningExecutionState):\n",
    "    goal = state['goal']\n",
    "    executed_tasks = state['executed_tasks']\n",
    "    total_tasks = len(state['plan'])\n",
    "    \n",
    "    success = len(executed_tasks) == total_tasks\n",
    "    \n",
    "    report = f\"\"\"Project Report:\n",
    "- Goal: {goal}\n",
    "- Status: {'SUCCESS' if success else 'PARTIAL'}\n",
    "- Tasks Completed: {len(executed_tasks)}/{total_tasks}\n",
    "- Resources Used: {', '.join(state.get('resources_needed', []))}\n",
    "- Execution Log: {len(state.get('execution_log', []))} entries\n",
    "\"\"\"\n",
    "    \n",
    "    execution_log = state.get('execution_log', []) + [f\"Final report generated. Success: {success}\"]\n",
    "    \n",
    "    return {\n",
    "        'execution_log': execution_log\n",
    "    }\n",
    "\n",
    "# Build the planning and execution graph\n",
    "def create_planning_execution_graph():\n",
    "    workflow = StateGraph(PlanningExecutionState)\n",
    "    \n",
    "    # Add nodes\n",
    "    workflow.add_node('generate_plan', generate_plan)\n",
    "    workflow.add_node('execute_tasks', execute_tasks)\n",
    "    workflow.add_node('monitor_execution', monitor_execution)\n",
    "    workflow.add_node('generate_report', generate_report)\n",
    "    \n",
    "    # Set entry point\n",
    "    workflow.set_entry_point('generate_plan')\n",
    "    \n",
    "    # Add edges\n",
    "    workflow.add_edge('generate_plan', 'execute_tasks')\n",
    "    workflow.add_edge('execute_tasks', 'monitor_execution')\n",
    "    workflow.add_edge('monitor_execution', 'generate_report')\n",
    "    workflow.add_edge('generate_report', END)\n",
    "    \n",
    "    return workflow.compile()"
   ]
  },
