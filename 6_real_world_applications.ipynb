    "## 1. Conversational AI Assistants\\n\\nLearning objectives:\\n- Build sophisticated chatbots with memory\\n- Implement context-aware conversations\\n- Design dialogue management systems"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tutorial 1: Conversational AI Assistants\n",
    "\n",
    "# Define state for conversational agent\n",
    "class ConversationState(TypedDict):\n",
    "    user_input: str\n",
    "    chat_history: List[Dict[str, str]]\n",
    "    context: Dict[str, Any]\n",
    "    current_intent: str\n",
    "    response: str\n",
    "    needs_followup: bool\n",
    "    user_profile: Dict[str, Any]\n",
    "\n",
    "# Simple memory storage for user profiles\n",
    "user_profiles = {}\n",
    "\n",
    "# Function to get user profile (in real app, this would connect to a DB)\n",
    "def get_user_profile(user_id: str) -> Dict[str, Any]:\n",
    "    if user_id not in user_profiles:\n",
    "        user_profiles[user_id] = {\n",
    "            'preferences': {},\n",
    "            'history': [],\n",
    "            'last_interaction': None\n",
    "        }\n",
    "    return user_profiles[user_id]\n",
    "\n",
    "# Intent classification node\n",
    "def classify_intent(state: ConversationState):\n",
    "    user_input = state['user_input'].lower()\n",
    "    \n",
    "    if any(word in user_input for word in ['hello', 'hi', 'hey', 'greetings']):\n",
    "        intent = 'greeting'\n",
    "    elif any(word in user_input for word in ['help', 'assist', 'support']):\n",
    "        intent = 'help_request'\n",
    "    elif any(word in user_input for word in ['order', 'purchase', 'buy']):\n",
    "        intent = 'order_query'\n",
    "    elif any(word in user_input for word in ['return', 'refund', 'cancel']):\n",
    "        intent = 'return_query'\n",
    "    elif any(word in user_input for word in ['account', 'profile', 'settings']):\n",
    "        intent = 'account_query'\n",
    "    else:\n",
    "        intent = 'general_query'\n",
    "    \n",
    "    return {'current_intent': intent}\n",
    "\n",
    "# Greeting handler\n",
    "def handle_greeting(state: ConversationState):\n",
    "    user_id = state.get('context', {}).get('user_id', 'default')\n",
    "    user_profile = get_user_profile(user_id)\n",
    "    \n",
    "    greeting_response = f\"Hello! How can I assist you today? I see you're a valued customer.\"\n",
    "    \n",
    "    # Update chat history\n",
    "    new_history = state.get('chat_history', []) + [\n",
    "        {'role': 'user', 'content': state['user_input']},\n",
    "        {'role': 'assistant', 'content': greeting_response}\n",
    "    ]\n",
    "    \n",
    "    return {\n",
    "        'response': greeting_response,\n",
    "        'chat_history': new_history,\n",
    "        'needs_followup': True,\n",
    "        'user_profile': user_profile\n",
    "    }\n",
    "\n",
    "# Help request handler\n",
    "def handle_help_request(state: ConversationState):\n",
    "    user_id = state.get('context', {}).get('user_id', 'default')\n",
    "    user_profile = get_user_profile(user_id)\n",
    "    \n",
    "    help_response = \"I'm here to help! You can ask me about orders, returns, account information, or general questions. What specifically do you need assistance with?\"\n",
    "    \n",
    "    # Update chat history\n",
    "    new_history = state.get('chat_history', []) + [\n",
    "        {'role': 'user', 'content': state['user_input']},\n",
    "        {'role': 'assistant', 'content': help_response}\n",
    "    ]\n",
    "    \n",
    "    return {\n",
    "        'response': help_response,\n",
    "        'chat_history': new_history,\n",
    "        'needs_followup': True,\n",
    "        'user_profile': user_profile\n",
    "    }\n",
    "\n",
    "# Order query handler\n",
    "def handle_order_query(state: ConversationState):\n",
    "    user_id = state.get('context', {}).get('user_id', 'default')\n",
    "    user_profile = get_user_profile(user_id)\n",
    "    \n",
    "    order_response = f\"I can help you with your order. Based on our records, you have {len(user_profile.get('orders', []))} recent orders. Could you please provide your order number for more specific assistance?\"\n",
    "    \n",
    "    # Update chat history\n",
    "    new_history = state.get('chat_history', []) + [\n",
    "        {'role': 'user', 'content': state['user_input']},\n",
    "        {'role': 'assistant', 'content': order_response}\n",
    "    ]\n",
    "    \n",
    "    return {\n",
    "        'response': order_response,\n",
    "        'chat_history': new_history,\n",
    "        'needs_followup': True,\n",
    "        'user_profile': user_profile\n",
    "    }\n",
    "\n",
    "# General query handler\n",
    "def handle_general_query(state: ConversationState):\n",
    "    user_id = state.get('context', {}).get('user_id', 'default')\n",
    "    user_profile = get_user_profile(user_id)\n",
    "    \n",
    "    # In a real implementation, this might call an LLM for more sophisticated responses\n",
    "    general_response = f\"Thanks for your message: '{state['user_input']}'. I've noted your query in your profile. Is there anything specific I can help you with?\"\n",
    "    \n",
    "    # Update chat history\n",
    "    new_history = state.get('chat_history', []) + [\n",
    "        {'role': 'user', 'content': state['user_input']},\n",
    "        {'role': 'assistant', 'content': general_response}\n",
    "    ]\n",
    "    \n",
    "    # Update user profile with the query\n",
    "    user_profile['history'].append({'query': state['user_input'], 'timestamp': 'now'})\n",
    "    \n",
    "    return {\n",
    "        'response': general_response,\n",
    "        'chat_history': new_history,\n",
    "        'needs_followup': True,\n",
    "        'user_profile': user_profile\n",
    "    }\n",
    "\n",
    "# Route based on intent\n",
    "def route_by_intent(state: ConversationState):\n",
    "    intent = state.get('current_intent', 'general_query')\n",
    "    \n",
    "    if intent == 'greeting':\n",
    "        return 'handle_greeting'\n",
    "    elif intent == 'help_request':\n",
    "        return 'handle_help_request'\n",
    "    elif intent == 'order_query':\n",
    "        return 'handle_order_query'\n",
    "    else:\n",
    "        return 'handle_general_query'\n",
    "\n",
    "# Build the conversational AI graph\n",
    "def create_conversational_ai_graph():\n",
    "    workflow = StateGraph(ConversationState)\n",
    "    \n",
    "    # Add nodes\n",
    "    workflow.add_node('classify_intent', classify_intent)\n",
    "    workflow.add_node('handle_greeting', handle_greeting)\n",
    "    workflow.add_node('handle_help_request', handle_help_request)\n",
    "    workflow.add_node('handle_order_query', handle_order_query)\n",
    "    workflow.add_node('handle_general_query', handle_general_query)\n",
    "    \n",
    "    # Set entry point\n",
    "    workflow.set_entry_point('classify_intent')\n",
    "    \n",
    "    # Add conditional edges\n",
    "    workflow.add_conditional_edges(\n",
    "        'classify_intent',\n",
    "        route_by_intent,\n",
    "        {\n",
    "            'handle_greeting': 'handle_greeting',\n",
    "            'handle_help_request': 'handle_help_request',\n",
    "            'handle_order_query': 'handle_order_query',\n",
    "            'handle_general_query': 'handle_general_query'\n",
    "        }\n",
    "    )\n",
    "    \n",
    "    # Add edges from handlers to end\n",
    "    workflow.add_edge('handle_greeting', END)\n",
    "    workflow.add_edge('handle_help_request', END)\n",
    "    workflow.add_edge('handle_order_query', END)\n",
    "    workflow.add_edge('handle_general_query', END)\n",
    "    \n",
    "    return workflow.compile()"
   ]
  },
